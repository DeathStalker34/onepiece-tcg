# Hoist only well-known dev tools so workspace deps stay explicit
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=*typescript*
public-hoist-pattern[]=*prisma*

# Strict peer deps surface version conflicts early
strict-peer-dependencies=true

# Don't auto-install peer deps silently
auto-install-peers=false

# Keep output tidy
reporter=default
